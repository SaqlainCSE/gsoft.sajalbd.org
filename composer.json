{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.0",
        "appslabke/lara-izitoast": "^1.1",
        "carlos-meneses/laravel-mpdf": "^2.1",
        "doctrine/dbal": "^3.6",
        "dyrynda/laravel-efficient-uuid": "^4.3",
        "dyrynda/laravel-model-uuid": "^6.4",
        "fakerphp/faker": "^1.9.1",
        "fruitcake/laravel-cors": "^2.0",
        "guzzlehttp/guzzle": "^7.0.1",
        "haruncpi/laravel-user-activity": "^1.0",
        "juststeveking/http-status-code": "^2.0",
        "laravel/framework": "^9.0",
        "laravel/horizon": "^5.10",
        "laravel/sanctum": "^2.11",
        "laravel/slack-notification-channel": "^2.5",
        "laravel/telescope": "^4.15",
        "laravel/tinker": "^2.5",
        "laravelcollective/html": "^6.2",
        "maatwebsite/excel": "^3.1",
        "owen-it/laravel-auditing": "^13.0",
        "propaganistas/laravel-phone": "^4.3",
        "pusher/pusher-php-server": "^7.2",
        "rap2hpoutre/laravel-log-viewer": "^2.3",
        "spatie/flysystem-dropbox": "^3.0",
        "spatie/laravel-backup": "^8.1",
        "spatie/laravel-medialibrary": "^10.0.0",
        "spatie/laravel-permission": "^5.5",
        "wildside/userstamps": "^2.1"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.16",
        "barryvdh/laravel-ide-helper": "^2.12",
        "deployer/deployer": "^7.0",
        "ibex/crud-generator": "^1.3",
        "laravel/sail": "^1.0.1",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^6.1",
        "phpunit/phpunit": "^9.5.10",
        "spatie/laravel-ignition": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helpers/Helpers.php",
            "app/Helpers/Settings.php",
            "app/Helpers/CloudflareHelper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                
                "barryvdh/laravel-ide-helper"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "platform": {
            "ext-pcntl": "8.0",
            "ext-posix": "8.0"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
